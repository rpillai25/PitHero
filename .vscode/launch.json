{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    
    "version": "0.2.0",
    "configurations": [
        // Modern .NET configurations (recommended for .NET 8.0)
        {
            "name": ".NET: Launch",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "dotnet: build (Debug)",
            "program": "${workspaceFolder}/PitHero/bin/Debug/PitHero.dll",
            "args": [],
            "cwd": "${workspaceFolder}/PitHero",
            "stopAtEntry": false,
            "console": "internalConsole"
        },
        {
            "name": ".NET: Launch Without Building",
            "type": "coreclr",
            "request": "launch",
            "program": "${workspaceFolder}/PitHero/bin/Debug/PitHero.dll",
            "args": [],
            "cwd": "${workspaceFolder}/PitHero",
            "stopAtEntry": false,
            "console": "internalConsole"
        },
        {
            "name": ".NET: Attach to Process",
            "type": "coreclr",
            "request": "attach"
        },

        // Legacy Mono/CLR configurations (for backward compatibility)
        {
            "name": "Launch (Mac)",
            "type": "mono",
            "request": "launch",
            "program": "${workspaceFolder}/PitHero/bin/Debug/PitHero.exe",
            "cwd": "${workspaceFolder}/PitHero",
            "preLaunchTask": "Build (Debug)",
            "osx":{
                "env": {
                    "DYLD_LIBRARY_PATH": "${workspaceFolder}/PitHero/bin/Debug/osx/"
                }
            }
        },
		
        {
            "name": "Launch Without Building (Mac)",
            "type": "mono",
            "request": "launch",
            "program": "${workspaceFolder}/PitHero/bin/Debug/PitHero.exe",
            "cwd": "${workspaceFolder}",
            "osx":{
                "env": {
                    "DYLD_LIBRARY_PATH": "${workspaceFolder}/PitHero/bin/Debug/osx/"
                }
            }
        },

        {
            "name": "Launch (Windows)",
            "type": "clr",
            "request": "launch",
            "program": "${workspaceFolder}/PitHero/bin/Debug/PitHero.exe",
            "cwd": "${workspaceFolder}/PitHero",
            "preLaunchTask": "Build (Debug)"
        },
		
        {
            "name": "Launch Without Building (Windows)",
            "type": "clr",
            "request": "launch",
            "program": "${workspaceFolder}/PitHero/bin/Debug/PitHero.exe",
            "cwd": "${workspaceFolder}"
        },

        {
            "name": "Attach",
            "type": "mono",
            "request": "attach",
            "address": "localhost",
            "port": 55555
        }
    ]
}
